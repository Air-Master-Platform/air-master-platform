# Postgres connection. Fill PASSWORD with the real DB password.
# Source psql cmd: psql -d air_master -U air_masterdb -h loxk.your-database.de
PGHOST=loxk.your-database.de
PGPORT=5432
PGDATABASE=air_master
PGUSER=air_masterdb
PGPASSWORD=PUT_DB_PASSWORD_HERE

# Optional single-URL form (overrides the PG* vars above if set)
# DATABASE_URL=postgres://air_masterdb:PASSWORD@loxk.your-database.de:5432/air_master

# Session secret - change to a long random string
SESSION_SECRET=change-me-to-a-long-random-string

# Server port
PORT=3000

# --- Air Master Agent (n8n) ---
# n8n Chat Trigger webhook. agent.js forwards chat here and returns the reply.
N8N_AGENT_WEBHOOK=https://donedl-n8n.fly.dev/webhook/air-master-agent/chat
